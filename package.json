{
  "name": "@shervnariman/slopcheck",
  "version": "0.1.0",
  "description": "Local, deterministic patch risk scanner that catches risky AI-generated or hard-to-review code changes before they land.",
  "type": "module",
  "bin": {
    "slopcheck": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "cli",
    "code-review",
    "static-analysis",
    "git-diff",
    "ai-generated-code",
    "developer-tools"
  ],
  "author": "Sherv Nariman",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShervNariman/SlopCheck.git"
  },
  "bugs": {
    "url": "https://github.com/ShervNariman/SlopCheck/issues"
  },
  "homepage": "https://github.com/ShervNariman/SlopCheck#readme",
  "publishConfig": {
    "access": "public"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.10.0",
      "onFail": "download"
    }
  },
  "dependencies": {
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
